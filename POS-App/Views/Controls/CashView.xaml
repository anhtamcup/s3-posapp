<UserControl x:Class="POS_App.Views.Controls.CashView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:POS_App.Views.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="InfoTextLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
            <Setter Property="Foreground" Value="#474747"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>

        <Style x:Key="InfoTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F4F6FA"/>
            <Setter Property="BorderBrush" Value="#CCD2E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock
            Text="Số tiền khách đưa"
            Style="{StaticResource InfoTextLabel}" />
        <TextBox
            x:Name="txtCustomerAmount"
            Style="{StaticResource InfoTextBox}"
            Text="{Binding CustomerPaid,
            Mode=TwoWay,
            UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock Text="Số tiền chuyển khoản" Style="{StaticResource InfoTextLabel}" />
        <TextBox  Style="{StaticResource InfoTextBox}" x:Name="txtTransferAmount" Text="0" />
        <TextBlock Text="Tiền trả lại" Style="{StaticResource InfoTextLabel}" />
        <TextBox Text="{Binding ChangeAmount,StringFormat='{}{0:N0} đ', Mode=OneWay}" IsReadOnly="True" Style="{StaticResource InfoTextBox}" x:Name="txtChange" />
    </StackPanel>
</UserControl>
