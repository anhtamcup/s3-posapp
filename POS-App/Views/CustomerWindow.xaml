<Window x:Class="POS_App.Views.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:POS_App.ViewModels"
        Title="CustomerWindow"
        Height="450"
        Width="800">


    <Window.Resources>
        <!-- LinearGradientBrush dọc (giống Illustrator) -->
        <LinearGradientBrush x:Key="NavyGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0A3D62" Offset="0.0"/>
            <GradientStop Color="#134D75" Offset="0.5"/>
            <GradientStop Color="#0A3D62" Offset="1.0"/>
        </LinearGradientBrush>

        <Style x:Key="SummaryTotalPriceLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="SummaryTotalPriceValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#00824A"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeXL}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SummarySubtotalPriceLabel" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="Foreground" Value="#2E384E"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="SummarySubtotalPriceValue" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#2E384E"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Name="panelHeader"
            Background="{StaticResource BackgroundColorHeader}">
            <!-- Logo -->
            <StackPanel
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
                <TextBlock
                        Text="S3POS"
                        FontSize="25"
                        FontWeight="Bold"
                        Foreground="White"
                        VerticalAlignment="Center"/>
                <Border
                        Width="1"
                        Background="#FFFFFF"
                        Margin="10,0"/>
            </StackPanel>
        </Grid>


        <Grid Grid.Row="1" Background="{StaticResource NavyGradient}">


            <Border Margin="30" Background="#FFFFFF" CornerRadius="20">
                <Grid Margin="15" >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="SẢN PHẨM ĐANG MUA"
                        Foreground="#2E384E"
                        FontWeight="Bold"
                        FontSize="{StaticResource FontSizeXL}" />
                    <Grid Grid.Row="1" Margin="0,10,0,0">

                        <DataGrid x:Name="CartGrid"
                            ItemsSource="{Binding CurrentView.CartItems}"
                            AutoGenerateColumns="False"
                            HeadersVisibility="None"
                            GridLinesVisibility="None"
                            BorderThickness="0"
                            Background="Transparent"
                            RowHeaderWidth="0"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            CanUserResizeColumns="False"
                            CanUserSortColumns="False"
                            SelectionMode="Single" >

                            <DataGrid.Resources>

                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>

                                <Style TargetType="DataGridRow">
                                    <Setter Property="Height" Value="42"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="45">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="30"
                                        Height="30"
                                        CornerRadius="3"
                                        Background="#EEF2F7"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">

                                                <TextBlock Text="{Binding Index}"
                                            FontSize="{StaticResource FontSizeM}"
                                            Foreground="#5D6679"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>

                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="{StaticResource FontSizeM}" Foreground="#2E384E"/>
                                                <TextBlock FontSize="{StaticResource FontSizeS}" Foreground="#8696AD">
                                                    <Run Text="{Binding Code}" />
                                                    <Run Text="  " />
                                                    <Run Text="{Binding OriginalPrice,StringFormat='{}{0:N0} đ'}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Quantity,StringFormat='x{0}'}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource FontSizeM}"
                                        Foreground="#2E384E"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>


                                <DataGridTemplateColumn Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TotalPrice,StringFormat='{}{0:N0} đ'}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        FontSize="{StaticResource FontSizeM}"
                                        Margin="0,0,5,0"
                                        Foreground="#2E384E"/>

                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                        </DataGrid>
                    </Grid>
                    <Grid Grid.Row="2" VerticalAlignment="Bottom" DataContext="{Binding CurrentView.Summary}" >

                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <Rectangle
                            Grid.Row="0"
                            Height="0.8"
                            VerticalAlignment="Top"
                            Stroke="#8A96B3"
                            StrokeThickness="1"
                            StrokeDashArray="1 3"
                            Fill="#2E384E"
                            IsHitTestVisible="False"
                            Margin="0,0,0,10"/>
                        
                        <TextBlock Grid.Row="1" Text="{Binding ItemCount, StringFormat='Tổng: {0} sản phẩm'}" Style="{StaticResource SummarySubtotalPriceLabel}" />
                        <TextBlock Grid.Row="1" Text="{Binding SubTotalAmount,StringFormat='{}{0:N0} đ'}" Style="{StaticResource SummarySubtotalPriceValue}" />

                        <TextBlock Grid.Row="2" Text="Khuyến mãi / Giảm giá"  Style="{StaticResource SummarySubtotalPriceLabel}"/>
                        <TextBlock Grid.Row="2" Text="{Binding PromotionAmount,StringFormat='{}{0:N0} đ'}"  Style="{StaticResource SummarySubtotalPriceValue}" />

                        <TextBlock Grid.Row="3" Text="VAT (đã bao gồm)" Style="{StaticResource SummarySubtotalPriceLabel}" />
                        <TextBlock Grid.Row="3" Text="{Binding VATAmount,StringFormat='{}{0:N0} đ'}" Style="{StaticResource SummarySubtotalPriceValue}" />

                        <Grid Grid.Row="4">
                            <Rectangle Height="0.8"
                            VerticalAlignment="Top"
                            Stroke="#8A96B3"
                            StrokeThickness="1"
                            StrokeDashArray="1 3"
                            Fill="#2E384E"
                            IsHitTestVisible="False"/>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TỔNG CỘNG" Style="{StaticResource SummaryTotalPriceLabel}" />
                                <TextBlock Text="{Binding TotalAmount,StringFormat='{}{0:N0} đ'}" Grid.Column="1" Style="{StaticResource SummaryTotalPriceValue}" />
                            </Grid>
                        </Grid>

                    </Grid>


                </Grid>
            </Border>

        </Grid>


    </Grid>

</Window>