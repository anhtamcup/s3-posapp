<UserControl x:Class="POS_App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- Keypad -->
        <Style x:Key="KeypadButtonNumberStyle"
               TargetType="Button"
               BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
            <Setter Property="Background" Value="#F4F4F4"/>
        </Style>

        <Style x:Key="KeypadButtonEnterStyle"
               TargetType="Button"
               BasedOn="{StaticResource KeypadButtonNumberStyle}">
            <Setter Property="Height" Value="100"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#15B84E"/>
        </Style>

        <!-- Bottom Buttons -->
        <Style x:Key="ActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ButtonBase}">

            <Setter Property="Height" Value="80"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeM}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Opacity"
                                        Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

        <!-- Input -->

        <Style x:Key="InputLabelStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2E384E"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
        </Style>

        <Style x:Key="InputBorderStyle"
               TargetType="Border">
            <Setter Property="Background" Value="#80CCD2E3"/>
            <Setter Property="BorderBrush" Value="#D9D9D9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>

        <Style x:Key="InputBoxStyle"
               TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PasswordInputBoxStyle"
               TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- LOGIN -->

        <Grid Grid.Row="0">

            <Border Width="280"
                    Padding="15"
                    Background="White"
                    BorderBrush="#D9D9D9"
                    BorderThickness="1"
                    CornerRadius="15"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="S3POS"
                               FontSize="25"
                               FontWeight="Bold"
                               Foreground="#1E73E8"
                               HorizontalAlignment="Center"/>

                    <StackPanel Margin="0,15,0,10">

                        <TextBlock Text="Mã nhân viên:"
                                   Style="{StaticResource InputLabelStyle}"/>

                        <Border Style="{StaticResource InputBorderStyle}">
                            <TextBox x:Name="tbStaffCode" Style="{StaticResource InputBoxStyle}" Text="tamla@cfox.vn"/>
                        </Border>

                        <TextBlock Text="Mật khẩu:"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource InputLabelStyle}"/>

                        <Border Style="{StaticResource InputBorderStyle}">
                            <PasswordBox x:Name="tbPassword" Style="{StaticResource PasswordInputBoxStyle}" Password="123456"/>
                        </Border>

                    </StackPanel>

                    <!-- keypad -->

                    <Grid Background="#DCE5EF">

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Content="7" Click="Number_Click" Style="{StaticResource KeypadButtonNumberStyle}"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="8" Click="Number_Click" Style="{StaticResource KeypadButtonNumberStyle}"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="9" Click="Number_Click" Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="0"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Content="Backspace"
                                Click="Backspace_Click"
                                Background="#2563EB"
                                Foreground="White"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="1" Grid.Column="0" Content="4" Click="Number_Click" Style="{StaticResource KeypadButtonNumberStyle}"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="5" Click="Number_Click" Style="{StaticResource KeypadButtonNumberStyle}"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="6" Click="Number_Click" Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="1"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Content="Clear"
                                Click="Clear_Click"
                                Background="#F54545"
                                Foreground="White"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="2" Grid.Column="0" Content="1" Click="Number_Click" Style="{StaticResource KeypadButtonNumberStyle}"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="2" Click="Number_Click" Style="{StaticResource KeypadButtonNumberStyle}"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="3" Click="Number_Click" Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="2"
                                Grid.Column="3"
                                Grid.RowSpan="2"
                                Grid.ColumnSpan="2"
                                Content="Enter"
                                Click="Enter_Click"
                                Style="{StaticResource KeypadButtonEnterStyle}"/>

                        <Button Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Content="0"
                                Click="Number_Click"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                    </Grid>

                </StackPanel>

            </Border>

        </Grid>

        <!-- Bottom Buttons -->

        <UniformGrid Grid.Row="1" Columns="4">

            <Button Content="Bán hàng" Background="#18D56D" Style="{StaticResource ActionButtonStyle}"/>
            <Button Content="Bảng kê quyết toán" Background="#6172F3" Style="{StaticResource ActionButtonStyle}"/>
            <Button Content="Mở ca / Kết ca" Background="#2D31A6" Style="{StaticResource ActionButtonStyle}"/>
            <Button Content="Nộp / Rút tiền" Background="#E0A000" Style="{StaticResource ActionButtonStyle}"/>

        </UniformGrid>

        <UniformGrid Grid.Row="2" Columns="5">

            <Button Content="Quản lý" Background="#0B4A6F" Style="{StaticResource ActionButtonStyle}"/>
            <Button Content="Mở ca / Kết ca" Background="#2D31A6" Style="{StaticResource ActionButtonStyle}"/>
            <Button Content="Đồng bộ" Background="#065986" Style="{StaticResource ActionButtonStyle}"/>
            <Button Content="Đối soát" Background="#2D3282" Style="{StaticResource ActionButtonStyle}"/>

            <Button Name="BtnExitFunction"
                    Content="Thoát"
                    Background="#065986"
                    Click="BtnExitFunction_Click"
                    Style="{StaticResource ActionButtonStyle}"/>

        </UniformGrid>

        <!-- Select Branch -->

        <Grid x:Name="BranchOverlay"
      Visibility="Collapsed"
      Background="#70000000"
      Panel.ZIndex="998">

            <Border Width="420"
            MaxHeight="500"
            Background="White"
            CornerRadius="14"
            Padding="18"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->

                    <StackPanel Grid.Row="0"
                        Margin="0,0,0,10">

                        <TextBlock Text="Chọn chi nhánh"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                        <TextBlock Text="Vui lòng chọn chi nhánh để đăng nhập"
                           FontSize="12"
                           Foreground="#888"
                           HorizontalAlignment="Center"/>

                    </StackPanel>

                    <!-- Search -->

                    <Border Grid.Row="1"
                    Height="38"
                    Margin="0,0,0,10"
                    Background="#F5F6F8"
                    CornerRadius="8">

                        <TextBox x:Name="txtSearchBranch"
                         BorderThickness="0"
                         Background="Transparent"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         Padding="10,0"
                                 />
                    </Border>

                    <!-- Branch list -->

                    <ListBox x:Name="lbBranches"
                     Grid.Row="2"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <ListBox.ItemTemplate>

                            <DataTemplate>

                                <Border x:Name="ItemBorder"
                                Margin="0,0,0,6"
                                Padding="12"
                                Background="#F8F9FC"
                                CornerRadius="8">

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="35"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                           Text="🏢"
                                           FontSize="16"
                                           VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1">

                                            <TextBlock Text="{Binding BranchName}"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>

                                            <TextBlock Text="{Binding BranchCode}"
                                               FontSize="11"
                                               Foreground="#888"/>

                                        </StackPanel>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </ListBox.ItemTemplate>

                        <ListBox.ItemContainerStyle>

                            <Style TargetType="ListBoxItem">

                                <Setter Property="BorderThickness"
                                Value="0"/>

                                <Setter Property="Padding"
                                Value="0"/>

                                <Style.Triggers>

                                    <Trigger Property="IsSelected"
                                     Value="True">

                                        <Setter Property="Background"
                                        Value="#EAF2FF"/>

                                    </Trigger>

                                </Style.Triggers>

                            </Style>

                        </ListBox.ItemContainerStyle>

                    </ListBox>

                    <!-- Button -->

                    <Button Grid.Row="3"
                     Content="Xác nhận"
                     Margin="0,12,0,0"
                     Height="42"
                     FontWeight="SemiBold"
                     Background="#1E73E8"
                     Foreground="White"
                     Click="BtnConfirmBranch_Click"/>

                </Grid>

            </Border>

        </Grid>

        <!-- Loading -->

        <Grid x:Name="LoadingOverlay"
              Visibility="Collapsed"
              Background="#80000000"
              Panel.ZIndex="999">

            <Border Width="220"
                    Height="120"
                    Background="White"
                    CornerRadius="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <ProgressBar Width="150"
                                 Height="8"
                                 IsIndeterminate="True"/>

                    <TextBlock Text="Đang đăng nhập..."
                               Margin="0,15,0,0"
                               FontSize="16"
                               HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</UserControl>